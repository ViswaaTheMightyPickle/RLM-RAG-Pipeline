# LM Studio Configuration
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Model IDs (as they appear in LM Studio)
# Worker Model: 0.5B-1.5B parameter model for distillation and gating
WORKER_MODEL_ID=qwen2.5-0.5b-instruct

# Root Model: 4B+ parameter model for final reasoning
ROOT_MODEL_ID=qwen/qwen3-vl-4b

# Embedding Model: Use LM Studio's embedding API
EMBEDDING_MODEL_ID=text-embedding-nomic-embed-text-v1.5

# RAG Configuration
CHUNK_SIZE=4000
SUMMARY_SIZE=500
VOTING_ITERATIONS=3
VOTING_THRESHOLD=0.7

# Data Directory
DATA_DIR=./data

# Ingestion Configuration
# Comma-separated glob patterns for files to include
INCLUDE_PATTERNS=*.pdf,*.epub,*.txt,*.text,*.md,*.mdx,*.markdown,*.mdown,*.mkd,*.mkdn,*.htm,*.html,*.xhtml

# Comma-separated patterns for directories/files to exclude
EXCLUDE_PATTERNS=node_modules,.git,__pycache__,*.pyc,*.pyo,*.pyd,venv,.venv,*.min.js,*.min.css

# LLM Request Timeout (in seconds)
# Increase if you experience timeouts during model inference
LLM_TIMEOUT=300
